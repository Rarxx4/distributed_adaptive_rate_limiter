{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Distributed Adaptive Rate Limiter — Day 13 observability dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Decisions per second (allowed vs rejected)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(rate_limit_decisions_total{decision=\"allowed\"}[1m])) by (algorithm)",
          "legendFormat": "allowed — {{algorithm}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(rate_limit_decisions_total{decision=\"rejected\"}[1m])) by (algorithm)",
          "legendFormat": "rejected — {{algorithm}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "rejected.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "allowed.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 2,
      "title": "Reject rate % by client",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * rate(rate_limit_decisions_total{decision=\"rejected\"}[1m]) / (rate(rate_limit_decisions_total[1m]) > 0)",
          "legendFormat": "{{clientId}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 3,
      "title": "Check latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rate_limit_latency_seconds_bucket[1m])) by (le, algorithm))",
          "legendFormat": "p50 — {{algorithm}}", "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rate_limit_latency_seconds_bucket[1m])) by (le, algorithm))",
          "legendFormat": "p95 — {{algorithm}}", "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(rate_limit_latency_seconds_bucket[1m])) by (le, algorithm))",
          "legendFormat": "p99 — {{algorithm}}", "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "title": "Adaptive limit value per client",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "adaptive_limit_value",
          "legendFormat": "{{clientId}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 5,
      "title": "Anomalies detected",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(anomaly_detected_total[1h]))",
          "legendFormat": "Anomalies (1 h)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 6,
      "title": "Circuit breaker open",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "darl_circuit_breaker_open", "legendFormat": "Open", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Closed", "color": "green" }, "1": { "text": "OPEN", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 7,
      "title": "Adaptive cache hit rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(darl_adaptive_cache_hits_total[1m]) / (rate(darl_adaptive_cache_hits_total[1m]) + rate(darl_adaptive_cache_misses_total[1m]))",
          "legendFormat": "Hit rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.8 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 8,
      "title": "Shadow divergence rate",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(darl_shadow_divergences_total[1m])",
          "legendFormat": "Divergences / s",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["darl", "rate-limiter", "adaptive"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "DARL — Distributed Adaptive Rate Limiter",
  "uid": "darl-main-v1",
  "version": 1
}
