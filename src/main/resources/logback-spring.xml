<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Human-readable console output for local dev (non-prod profiles) -->
    <springProfile name="!prod">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="com.darl.ratelimiter" level="DEBUG"/>
    </springProfile>

    <!-- Structured JSON output for prod — all fields include MDC keys -->
    <springProfile name="prod">
        <appender name="JSON_STDOUT" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <!-- Include all MDC fields: trace_id, client_id, algorithm -->
                <includeMdcKeyName>trace_id</includeMdcKeyName>
                <includeMdcKeyName>client_id</includeMdcKeyName>
                <includeMdcKeyName>algorithm</includeMdcKeyName>
                <fieldNames>
                    <timestamp>timestamp</timestamp>
                    <message>message</message>
                    <logger>logger</logger>
                    <thread>thread</thread>
                    <levelValue>[ignore]</levelValue>
                </fieldNames>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="JSON_STDOUT"/>
        </root>
    </springProfile>

</configuration>
